# Slack Socket Mode
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# LLM (LiteLLM). Contabo default example:
LLM_MODEL=openai/kimi-k2.7-code
OPENAI_API_KEY=
OPENAI_API_BASE=https://ollama.com/v1
# Or Anthropic: LLM_MODEL=claude-sonnet-4-6 + ANTHROPIC_API_KEY=...

# Web search — leave WEB_SEARCH_PROVIDER empty to auto-pick.
# Default (no key): ddgs. Or set one of:
# WEB_SEARCH_PROVIDER=tavily|brave|serper|firecrawl|ddgs
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPER_API_KEY=
# FIRECRAWL_API_KEY=

# Contabo-only Hermes MCP bridge (optional)
# HERMES_API_URL=http://127.0.0.1:8642
# HERMES_API_KEY=

DATA_DIR=./data
