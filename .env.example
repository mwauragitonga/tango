# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...   # Socket Mode token

# ── LLM provider ────────────────────────────────────────────────────────────
# Set LLM_MODEL to any LiteLLM model string and provide the matching API key.
#
# Anthropic (Claude)
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
#
# Google Gemini
# LLM_MODEL=gemini/gemini-2.0-flash
# GEMINI_API_KEY=...
#
# Groq (fast open-weight models)
# LLM_MODEL=groq/llama-3.3-70b-versatile
# GROQ_API_KEY=...
#
# Local Ollama (no key needed)
# LLM_MODEL=ollama/llama3
# ────────────────────────────────────────────────────────────────────────────

# Per-channel model override: add to channels/<id>/tools.toml:
#   [llm]
#   model = "gpt-4o"

# Storage
DATA_DIR=./data            # where SQLite DBs and channel configs live

# Optional: Mem0 for semantic recall (Phase 2)
# MEM0_API_KEY=...

# Optional: restrict which Slack workspaces can install
# ALLOWED_WORKSPACE_IDS=T01234,T05678
