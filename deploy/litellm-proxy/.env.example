# REQUIRED — generate strong values; never commit real secrets.
# LITELLM_SALT_KEY must be set once before storing provider credentials and NEVER rotated.

LITELLM_MASTER_KEY=sk-REPLACE-with-long-random
LITELLM_SALT_KEY=REPLACE-with-permanent-random-salt
POSTGRES_PASSWORD=REPLACE-strong-pg-password
REDIS_PASSWORD=REPLACE-strong-redis-password

# Provider keys (Proxy holds these; Tango workers use virtual keys only)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional pin:
# LITELLM_IMAGE=ghcr.io/berriai/litellm@sha256:REPLACE
